{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "IA-QA Evaluation Contract",
  "description": "Defines a suite of AI model evaluation tests. Save as <name>.ia-eval.yaml",
  "type": "object",
  "required": ["metadata", "scenarios"],
  "additionalProperties": false,
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["name", "version"],
      "additionalProperties": false,
      "properties": {
        "name":          { "type": "string", "minLength": 1, "maxLength": 200, "description": "Human-readable contract name" },
        "version":       { "type": "string", "pattern": "^\\d+\\.\\d+", "description": "SemVer version (e.g. 1.0)" },
        "description":   { "type": "string", "maxLength": 1000 },
        "tags":          { "type": "array", "items": { "type": "string", "maxLength": 50 }, "maxItems": 20 },
        "author":        { "type": "string", "maxLength": 200 },
        "created_at":    { "type": "string", "description": "ISO date string" },
        "model":         { "type": "string", "maxLength": 100, "description": "Default model (e.g. gpt-4o-mini)" },
        "provider":      { "type": "string", "maxLength": 50, "description": "Default provider: openai | anthropic | groq | google | hf" },
        "temperature":   { "type": "number", "minimum": 0, "maximum": 2 },
        "max_tokens":    { "type": "integer", "minimum": 1, "maximum": 100000 },
        "system_prompt": { "type": "string", "maxLength": 10000 }
      }
    },
    "scenarios": {
      "type": "array",
      "minItems": 1,
      "maxItems": 500,
      "items": {
        "type": "object",
        "required": ["id", "input"],
        "additionalProperties": false,
        "properties": {
          "id":            { "type": "string", "minLength": 1, "maxLength": 100, "pattern": "^[\\w\\-]+$" },
          "description":   { "type": "string", "maxLength": 500 },
          "input":         { "type": "string", "minLength": 1, "maxLength": 50000, "description": "User prompt sent to the model" },
          "ground_truth":  { "type": "string", "maxLength": 50000, "description": "Expected correct answer" },
          "system_prompt": { "type": "string", "maxLength": 10000 },
          "model":         { "type": "string", "maxLength": 100 },
          "provider":      { "type": "string", "maxLength": 50 },
          "temperature":   { "type": "number", "minimum": 0, "maximum": 2 },
          "tags":          { "type": "array", "items": { "type": "string", "maxLength": 50 }, "maxItems": 20 },
          "skip":          { "type": "boolean", "description": "Skip this scenario" },
          "expectations":  { "type": "object", "description": "Per-scenario expectation overrides", "additionalProperties": true }
        }
      }
    },
    "expectations": {
      "type": "object",
      "description": "Global pass criteria applied to all scenarios",
      "additionalProperties": false,
      "properties": {
        "min_score":        { "type": "number", "minimum": 0, "maximum": 100, "description": "Minimum score to PASS (0-100, default 70)" },
        "tone":             { "type": "string", "enum": ["professional", "friendly", "neutral", "technical"] },
        "language":         { "type": "string", "minLength": 2, "maxLength": 5, "description": "Expected ISO 639-1 language code" },
        "max_length":       { "type": "integer", "minimum": 1, "description": "Maximum output length in characters" },
        "no_hallucination": { "type": "boolean" },
        "no_toxicity":      { "type": "boolean" },
        "json_output":      { "type": "boolean", "description": "Expect model output to be valid JSON" },
        "contains":         { "type": "array", "items": { "type": "string", "maxLength": 500 }, "maxItems": 50 },
        "not_contains":     { "type": "array", "items": { "type": "string", "maxLength": 500 }, "maxItems": 50 },
        "regex":            { "type": "string", "maxLength": 500, "description": "Output must match this regex" }
      }
    },
    "evaluators": {
      "type": "array",
      "maxItems": 20,
      "description": "Ordered list of ia-qa scorer tools to invoke",
      "items": {
        "type": "object",
        "required": ["name"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "enum": [
              "exact_match", "contains_check", "not_contains_check",
              "json_format", "regex_match", "length_check",
              "hallucination_check", "toxicity_filter",
              "response_quality", "llm_as_judge", "cosine_similarity"
            ]
          },
          "weight": { "type": "number", "minimum": 0, "maximum": 1, "description": "Relative weight in final score (default 1)" },
          "config": { "type": "object", "description": "Scorer-specific config (pattern, strings, model…)" }
        }
      }
    }
  }
}
